# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
# this is a pnpm repo - the npm lockfile is not used (pnpm-lock.yaml is the source of truth)
/package-lock.json
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-artifacts/

# playwright
.playwright-verify/
/playwright-report/
/test-results/
/playwright/.cache/

# next.js
/.next/
/out/

# next-sitemap output (regenerated at build by the postbuild script)
/public/sitemap.xml
/public/sitemap-*.xml

# production
/build

# misc
.DS_Store
*.pem

# debug
debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editor configs
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.code-workspace
.idea/
*.swp
*.swo

# ai tool configs - commit instruction files, ignore runtime artifacts
.cursor/
.claude/
AGENTS.md

# local planning docs
PLAN.md
docs/design-reference-notes.md

# local reference files (cv, assets, private docs)
ref/

# git worktrees (per-branch checkouts live here, never tracked)
/worktrees/
